{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "r3: setup init",
            "type": "shell",
            "command": "${workspaceFolder}/setup.ps1 init",
            "problemMatcher": []
        },
        {
            "label": "r3: projects list",
            "type": "shell",
            "command": "${workspaceFolder}/.agents/scripts/projects.ps1 list",
            "problemMatcher": []
        },
        {
            "label": "r3: project add",
            "type": "shell",
            "command": "${workspaceFolder}/.agents/scripts/projects.ps1 add ${input:gitUrl}",
            "problemMatcher": []
        },
        {
            "label": "r3: project status",
            "type": "shell",
            "command": "${workspaceFolder}/.agents/scripts/projects.ps1 status ${input:projectName}",
            "problemMatcher": []
        },
        {
            "label": "r3: sources list",
            "type": "shell",
            "command": "${workspaceFolder}/.agents/scripts/sources.ps1 list",
            "problemMatcher": []
        },
        {
            "label": "r3: source link",
            "type": "shell",
            "command": "${workspaceFolder}/.agents/scripts/sources.ps1 link ${input:gitUrl}",
            "problemMatcher": []
        },
        {
            "label": "r3: sources sync",
            "type": "shell",
            "command": "${workspaceFolder}/.agents/scripts/sources.ps1 sync",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "gitUrl",
            "type": "promptString",
            "description": "Git URL (HTTPS or SSH)"
        },
        {
            "id": "projectName",
            "type": "promptString",
            "description": "Project name in the workspace root"
        }
    ]
}